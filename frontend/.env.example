# Only needed for local development, where Vite (this app) and the NestJS API
# run on different ports. Leave unset for production builds, where the frontend
# is served by the same NestJS process as the API (same-origin requests).
VITE_API_BASE_URL=http://localhost:3000

# Country discriminator — this deployment only ever deals with Italy visas.
VITE_COUNTRY=IT
