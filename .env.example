# Copy this file to .env in the project root before running `docker compose up`.

# App
PORT=3000

# Database (MySQL) - used by both the mysql and app services
DB_DATABASE=visa_verification
DB_USERNAME=visa_app
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme-root

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Initial admin user - create it after the containers are up by running the seed script
# (see README), it is not created automatically.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
