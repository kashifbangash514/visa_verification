# App
PORT=3000

# Allowed frontend origin for CORS. Defaults to https://evisa-bosnia-verification.com
# (the production frontend) when unset. Override for local dev (e.g. Vite dev server).
CORS_ORIGIN=http://localhost:5173

# Database (MySQL) - for local dev / Docker Compose
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=visa_app
DB_PASSWORD=changeme
DB_DATABASE=visa_verification

# On Railway: linking a MySQL plugin to this service auto-injects MYSQLHOST,
# MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE into the environment.
# The app falls back to those automatically when DB_HOST etc. above are not
# set, so no manual variable mapping is needed on Railway - just link the
# plugin. Shown here for reference only (placeholders, not real values):
# MYSQLHOST=mysql.railway.internal
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=changeme
# MYSQLDATABASE=railway

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Initial admin user, used by `npm run seed:admin`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional: absolute or relative path for uploaded files (defaults to ./uploads)
UPLOADS_DIR=./uploads

# On Railway: attach a Volume to this service and Railway auto-injects
# RAILWAY_VOLUME_MOUNT_PATH at runtime. The app prefers that over UPLOADS_DIR
# automatically when present, so uploaded files persist across redeploys -
# no manual variable mapping needed. Shown here for reference only:
# RAILWAY_VOLUME_MOUNT_PATH=/data/uploads
